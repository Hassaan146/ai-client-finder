# ============================================================================
#  AI CLIENT/LEAD FINDER — .env.example   (Phase 0/1: fill this, then validate)
# ----------------------------------------------------------------------------
#  HOW TO USE:
#    1. cp .env.example .env
#    2. Paste your REAL free keys in `.env` (NOT here). `.env` is gitignored.
#    3. Run:  python backend/scripts/validate_keys.py   (Phase 0b harness)
#       -> pings every key you filled, prints OK/FAIL + quota, skips empties.
#
#  🔑 MULTIPLE KEYS PER LLM PROVIDER (so it never breaks mid-run):
#    Every LLM var is a *pool* — comma-separated, add as many as you want:
#        XAI_API_KEYS=key_one,key_two,key_three
#    The key-pool manager rotates across them and fails over on 429/quota/error.
#    Put >=2 per provider you rely on. More keys = more headroom.
#
#  🆓 NO-KEY sources (DuckDuckGo, HN, Overpass, WHOIS...) are NOT here — the
#     engine queries them directly. Nothing for you to fill.
#
#  [CORE] = fill first to run the thin slice.  Full guide -> API_KEYS.md
# ============================================================================


# ─────────────────────────────  APP / INFRA  ───────────────────────────────
APP_ENV=development                       # development | production
SECRET_KEY=                               # [CORE] 32+ random chars. gen: openssl rand -hex 32
API_TOKEN=                                # [OPTIONAL] shared bearer token for POST /api/runs + /approve.
                                          #   Empty = auth disabled (local dev). Set it when exposing the
                                          #   API; clients must send: Authorization: Bearer <token>
DATABASE_URL=sqlite:///./dev.db           # [CORE] dev default sqlite; prod = postgresql://user:pass@host:5432/leadfinder
REDIS_URL=                                # [OPTIONAL] redis://localhost:6379/0 (GCF blackboard/cache; in-process ok v1)
ALLOWED_ORIGIN=http://localhost:3000      # CORS allowlist (no wildcard in prod)
# free-tier safety caps
MAX_TOKENS_PER_CALL=2000
USER_DAILY_TOKEN_BUDGET=200000            # approx LLM output tokens/day before runs are refused
USER_DAILY_RUN_LIMIT=20                   # runs/day (UTC) before POST /api/runs returns 429

# tuning (optional) — defaults shown; uncomment to override
#CARD_WORKERS=4                           # parallel card builders in the pipeline
#SCOUT_MAX_WORKERS=10                     # parallel source queries
#SCOUT_PER_QUERY_LIMIT=8                  # results per (source, query)
#SCOUT_MAX_QUERIES_PER_SOURCE=6
#SCOUT_MAX_LOCATIONS=3                    # locations looped by local adapters
#QUALIFIER_BATCH_SIZE=20                  # leads per scoring LLM call
#QUALIFIER_MAX_CANDIDATES=100             # hard cap on candidates scored
#QUALIFIER_MIN_FIT=4.0                    # drop leads scored below this
#PRIORITY_MIN_FIT=7.0                     # "contact first" threshold
#LLM_TIMEOUT=60.0
#LLM_TEMPERATURE=0.3
#SOURCE_TIMEOUT=20.0                      # per-source HTTP timeout (seconds)
#FETCH_TIMEOUT=15.0                       # SSRF-guarded page fetch timeout (seconds)
#MAX_FETCH_BYTES=500000
#KEY_COOLDOWN_SECONDS=60.0                # bench time for a failing LLM key
#RATE_LIMIT_PER_MIN=120                   # general per-IP request limit
#RUN_CREATES_PER_MIN=10                   # per-IP POST /api/runs limit


# ══════════════════  LLM PROVIDERS — KEY POOLS (comma-separated)  ═══════════
#  Need >=1 provider. Recommend 2-3 keys each for the ones you rely on.
XAI_API_KEYS=                             # [CORE] Grok. https://console.x.ai -> API Keys.  e.g. key1,key2
NVIDIA_API_KEYS=                          # [CORE] NIM (nvapi-...). https://build.nvidia.com/settings/api-keys
GROQ_API_KEYS=                            # [OPTIONAL] fast+free. https://console.groq.com/keys
OPENROUTER_API_KEYS=                      # [OPTIONAL] many :free models. https://openrouter.ai/keys
DEEPSEEK_API_KEYS=                        # [OPTIONAL] https://platform.deepseek.com/api_keys
GEMINI_API_KEYS=                          # [OPTIONAL] https://aistudio.google.com/app/apikey
# Which model per task tier (router picks provider from the model prefix)
LLM_MODEL_CHEAP=nvidia/meta/llama-3.1-8b-instruct   # scout/extract/validate
LLM_MODEL_BIG=xai/grok-2                             # diagnosis/pitch


# ══════════════════════  TIER A — META-SEARCH (search engines)  ═════════════
SEARXNG_BASE_URL=http://localhost:8080    # [CORE] ⚙️ self-host (Docker). primary backbone, no key
TAVILY_API_KEYS=                          # [CORE] pool. 1000/mo each. https://tavily.com
GOOGLE_PSE_API_KEY=                       # [OPTIONAL] 100/day. https://programmablesearchengine.google.com
GOOGLE_PSE_CX=
# DuckDuckGo, Marginalia, Common Crawl = 🆓 no key (engine-handled)


# ══════════════════════  TIER B — FREELANCE / JOB BOARDS  ═══════════════════
REDDIT_CLIENT_ID=                         # [CORE] https://www.reddit.com/prefs/apps (type: script)
REDDIT_CLIENT_SECRET=                     # [CORE] same page
REDDIT_USER_AGENT=leadfinder/0.1 by u/yourname
ADZUNA_APP_ID=                            # [OPTIONAL] https://developer.adzuna.com
ADZUNA_APP_KEY=
JOOBLE_API_KEY=                           # [OPTIONAL] https://jooble.org/api/about
USAJOBS_API_KEY=                          # [OPTIONAL] https://developer.usajobs.gov/apirequest
USAJOBS_EMAIL=                            # [OPTIONAL] your email = required User-Agent
GITHUB_TOKEN=                             # [OPTIONAL] read-only PAT. https://github.com/settings/tokens
PRODUCTHUNT_TOKEN=                        # [OPTIONAL] https://api.producthunt.com/v2/oauth/applications
# HN, RemoteOK, Remotive, We Work Remotely, Himalayas = 🆓 no key


# ══════════════════════════  TIER C — LOCAL / MAPS  ════════════════════════
OVERPASS_URL=https://overpass-api.de/api/interpreter   # [CORE] 🆓 OpenStreetMap (primary maps)
NOMINATIM_USER_AGENT=leadfinder/0.1 (your@email)       # 🆓 required UA for geocoding
YELP_API_KEY=                             # [OPTIONAL] https://www.yelp.com/developers/v3/manage_app


# ═══════════════════════  TIER D — COMPANY INTEL  ══════════════════════════
OPENCORPORATES_API_KEY=                   # [OPTIONAL] https://opencorporates.com/api_accounts/new
COMPANIES_HOUSE_API_KEY=                  # [OPTIONAL] UK. https://developer.company-information.service.gov.uk
SEC_USER_AGENT=leadfinder your@email      # 🆓 SEC EDGAR requires a UA
# Wikidata = 🆓 no key


# ═══════════════════════  TIER E — SOCIAL / INTENT  ════════════════════════
# X/Twitter intent = Grok live search (uses XAI_API_KEYS above)
MASTODON_INSTANCE=                        # [OPTIONAL] e.g. https://mastodon.social  //// not signing up
MASTODON_ACCESS_TOKEN=                    # [OPTIONAL] <instance>/settings/applications
BLUESKY_IDENTIFIER=                       # [OPTIONAL] e.g. yourname.bsky.social
BLUESKY_APP_PASSWORD=                     # [OPTIONAL] Settings -> App Passwords
TELEGRAM_BOT_TOKEN=                       # [OPTIONAL] via @BotFather


# ══════════════════════════  TIER F — TENDERS / GOV  ═══════════════════════
DATA_GOV_API_KEY=                         # [OPTIONAL] unlocks many US gov APIs. https://api.data.gov/signup
SAM_GOV_API_KEY=                          # [OPTIONAL] https://sam.gov -> Profile -> Account Details
# TED (EU), Grants.gov, USASpending = 🆓 no key


# ═══════════════════════  TIER G — TRIGGER SIGNALS  ════════════════════════
NEWSAPI_KEY=                              # [OPTIONAL] https://newsapi.org
# GDELT, Google Trends (pytrends) = 🆓 no key


# ══════════════════  TIER H — EMAIL VERIFY (contact waterfall)  ═════════════
REOON_API_KEY=                            # [OPTIONAL] https://emailverifier.reoon.com
MILLIONVERIFIER_API_KEY=                  # [OPTIONAL] https://www.millionverifier.com
# WHOIS/RDAP + LLM page-extract + pattern-guess = 🆓 no key